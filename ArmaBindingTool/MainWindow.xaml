<Window x:Class="ArmaBindingTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Arma Reforger HOTAS Mapper Pro" Height="750" Width="520">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="1. Detected Controllers:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="JoystickList" Height="60" Margin="0,0,0,10" Background="#F0F0F0"/>

            <TextBlock Text="2. Search &amp; Filter Actions:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="SearchBox" Margin="0,0,0,10" Padding="5" TextChanged="SearchBox_TextChanged" />

            <TextBlock Text="3. Assignments (Click to rebind):" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="ArmaActionsList" Height="320" Margin="0,0,0,15">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="440">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TechnicalName}" FontWeight="SemiBold" Width="250"/>
                                <TextBlock Text="{Binding Preset}" Foreground="Gray" Width="80" FontStyle="Italic"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CurrentBinding}" HorizontalAlignment="Right" Foreground="Blue" FontFamily="Consolas" FontWeight="Bold"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Live Controller Input:" FontWeight="Bold" Margin="0,0,0,5"/>
            <Border BorderBrush="Gray" BorderThickness="1" Background="Black" Padding="10" Margin="0,0,0,10">
                <TextBlock x:Name="StatusLabel" Text="Waiting..." FontSize="18" Foreground="Lime" FontFamily="Consolas" TextAlignment="Center"/>
            </Border>

            <Button x:Name="LoadFileButton" Content="Load Arma .conf File" Margin="0,5,0,5" Height="35" Click="LoadFileButton_Click"/>
            <TextBlock x:Name="FilePathLabel" Text="No file selected" FontSize="10" Foreground="Gray" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>